{
  "schema_version": 1,
  "release_mode": "real-workflow",
  "services": {
    "api": {
      "name": "argus-api",
      "env": {
        "APP_ENV": "production",
        "POETRY_VERSION": "2.1.3",
        "ARGUS_PERSISTENCE_MODE": "supabase",
        "ARGUS_DEV_MEMORY_FALLBACK": "false",
        "ARGUS_MARKET_DATA_PROVIDER_MODE": "live_provider",
        "MARKET_DATA_CACHE_TTL": "43200",
        "ARGUS_RUNTIME_EVENT_TIMEOUT_SECONDS": "180",
        "ARGUS_RUNTIME_EVENT_KEEPALIVE_SECONDS": "15",
        "ARGUS_CHECKPOINTER_MODE": "postgres",
        "ARGUS_MOCK_AUTH": "false",
        "ARGUS_STRATEGIES_ENABLED": "false",
        "ARGUS_PRIVATE_ALPHA_ONBOARDING_ENABLED": "false",
        "ARGUS_BACKTEST_JOBS_SHADOW_ENABLED": "true",
        "ARGUS_BACKTEST_JOBS_DISPATCH_ENABLED": "true",
        "ARGUS_BACKTEST_WORKFLOW_EXECUTION_ENABLED": "true",
        "ARGUS_BACKTEST_WORKFLOW_TASK": "argus-backtests/workflow_proof",
        "ARGUS_BACKTEST_REAL_WORKFLOW_TASK": "argus-backtests/run_backtest_job",
        "ARGUS_BACKTEST_JOBS_USER_RUNNING_LIMIT": "1",
        "ARGUS_BACKTEST_JOBS_USER_QUEUED_LIMIT": "2",
        "ARGUS_BACKTEST_JOBS_GLOBAL_RUNNING_LIMIT": "5",
        "ARGUS_BACKTEST_JOBS_GLOBAL_QUEUED_LIMIT": "10",
        "ARGUS_CONTEXT_PACKETS_ENABLED": "true",
        "ARGUS_CONTEXT_PACKET_BUDGET_SECONDS": "4",
        "ARGUS_TITLE_AUTOGEN_ENABLED": "true",
        "ARGUS_TITLE_AUTOGEN_TIMEOUT_MS": "250",
        "ARGUS_READINESS_ASSET_TIMEOUT_SECONDS": "25",
        "ARGUS_UTILITY_MODEL": "google/gemini-2.5-flash-lite",
        "ARGUS_UTILITY_FALLBACK_MODEL": "qwen/qwen3.5-9b",
        "ARGUS_CHAT_MODEL": "deepseek/deepseek-v4-flash",
        "ARGUS_CHAT_FALLBACK_MODEL": "qwen/qwen3.5-9b",
        "ARGUS_OPENROUTER_RESULT_SUMMARY_TIMEOUT_SECONDS": "30",
        "ARGUS_STRUCTURED_MODEL": "x-ai/grok-4.3",
        "ARGUS_STRUCTURED_FALLBACK_MODEL": "anthropic/claude-haiku-4.5",
        "ARGUS_CONTEXT_MODEL": "openai/gpt-oss-120b",
        "ARGUS_CONTEXT_FALLBACK_MODEL": "deepseek/deepseek-v4-flash",
        "ALPACA_PAPER_TRADING": "true"
      },
      "required_present": [
        "ARGUS_CORS_ALLOW_ORIGINS",
        "ARGUS_OPS_TOKEN",
        "DATABASE_URL",
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_JWT_SECRET",
        "RENDER_API_KEY",
        "OPENROUTER_API_KEY",
        "ALPACA_API_KEY",
        "ALPACA_SECRET_KEY"
      ],
      "optional": []
    },
    "web": {
      "name": "argus-app",
      "env": {
        "NEXT_PUBLIC_APP_ENV": "production",
        "NEXT_PUBLIC_MOCK_AUTH": "false",
        "NEXT_PUBLIC_ENABLE_SPANISH": "true",
        "NEXT_PUBLIC_STRATEGIES_ENABLED": "false",
        "NEXT_PUBLIC_COLLECTIONS_ENABLED": "false",
        "NEXT_PUBLIC_OMNISEARCH_ENABLED": "true",
        "NEXT_PUBLIC_PRIVATE_ALPHA_ONBOARDING_ENABLED": "false",
        "NEXT_PUBLIC_CHAT_EXPLORATORY_SUGGESTIONS_ENABLED": "false"
      },
      "required_present": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_ARGUS_API_URL"
      ],
      "optional": ["NEXT_PUBLIC_POSTHOG_KEY"]
    },
    "workflow": {
      "name": "argus-backtests",
      "env": {
        "ARGUS_RENDER_WORKFLOW_PROOF_TASK": "argus-backtests/workflow_proof",
        "ARGUS_WORKFLOW_PROOF_PLAN": "starter",
        "POETRY_VERSION": "2.1.3",
        "ARGUS_BACKTEST_WORKFLOW_TIMEOUT_SECONDS": "300",
        "ARGUS_MARKET_DATA_PROVIDER_MODE": "live_provider",
        "ENABLE_MARKET_DATA_CACHE": "false",
        "ALPACA_PAPER_TRADING": "true",
        "ARGUS_UTILITY_MODEL": "google/gemini-2.5-flash-lite",
        "ARGUS_UTILITY_FALLBACK_MODEL": "qwen/qwen3.5-9b",
        "ARGUS_CHAT_MODEL": "deepseek/deepseek-v4-flash",
        "ARGUS_CHAT_FALLBACK_MODEL": "qwen/qwen3.5-9b",
        "ARGUS_OPENROUTER_RESULT_SUMMARY_TIMEOUT_SECONDS": "30",
        "ARGUS_STRUCTURED_MODEL": "x-ai/grok-4.3",
        "ARGUS_STRUCTURED_FALLBACK_MODEL": "anthropic/claude-haiku-4.5",
        "ARGUS_CONTEXT_MODEL": "openai/gpt-oss-120b",
        "ARGUS_CONTEXT_FALLBACK_MODEL": "deepseek/deepseek-v4-flash"
      },
      "required_present": [
        "ARGUS_WORKFLOW_DATABASE_URL",
        "ALPACA_API_KEY",
        "ALPACA_SECRET_KEY",
        "OPENROUTER_API_KEY"
      ],
      "optional": [
        "ARGUS_RENDER_WORKFLOW_RELEASE_COMMIT",
        "ARGUS_RENDER_WORKFLOW_RELEASE_VERSION_ID"
      ]
    }
  },
  "workflow": {
    "proof_task": "argus-backtests/workflow_proof",
    "real_task": "argus-backtests/run_backtest_job",
    "health_status": "ready",
    "runtime_provider_mode": "live_provider"
  },
  "capabilities": {
    "spanish": true,
    "omnisearch": true,
    "strategies": false,
    "collections": false,
    "private_alpha_onboarding": false,
    "real_workflow_execution": true
  },
  "locales": {
    "supported": ["en", "es-419"],
    "required_static_keys": [
      "landing.sign_up_email",
      "auth.signup.submit",
      "auth.login.submit",
      "common.retry",
      "common.search",
      "chat.history.pinned",
      "chat.new_chat",
      "chat.confirmation.status.ready_to_run",
      "chat.confirmation.actions.run_backtest",
      "chat.simulation_complete",
      "chat.backtest_job.queued_title",
      "chat.backtest_job.running_title",
      "chat.backtest_job.failed_title",
      "chat.result_card.add_decision",
      "chat.result_card.save_decision",
      "chat.result_card.decision_note_placeholder",
      "chat.result_card.decision_states.promising",
      "chat.error_backtest",
      "command_palette.search_placeholder",
      "command_palette.type.evidence",
      "command_palette.ledger.decision_filters"
    ]
  },
  "canary": {
    "language": "es-419",
    "locale": "es-419",
    "prompt": "Prueba una estrategia de comprar y mantener AAPL y MSFT con pesos iguales desde el 1 de enero de 2025 hasta el 5 de junio de 2026 con 10000 dolares",
    "decision_state": "promising",
    "decision_note": "Canario de navegador 233: evidencia renderizada verificada.",
    "search_query": "AAPL",
    "required_steps": [
      "signup_login",
      "profile_hydration",
      "browser_owned_golden_path",
      "real_workflow_backtest",
      "single_run_admission",
      "finalized_identity",
      "decision_note",
      "reload_hydration",
      "omnisearch_source_identity",
      "spanish_static_ui",
      "private_identity_handoff",
      "deterministic_intercepted_recovery",
      "clean_browser_console"
    ]
  }
}
