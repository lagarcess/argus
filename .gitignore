# Environment files with secrets
# Root: Backend secrets (Alpaca, Supabase service role, JWT)
.env
# Frontend: Next.js frontend secrets
web/.env.local
web/.env.*.local
# Keep example files for reference (no secrets)
!.env.example
!web/.env.example

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environments
.venv/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Linting / Type checking
.ruff_cache/
.mypy_cache/

# IDE
.vscode/
.idea/
.cursor/

# Logs
*.log
logs/

# Temporary files
# Ignore everything in the temp folder...
temp/*
# ...but don't ignore the .gitkeep file itself
!temp/.gitkeep

# Joblib cache (market data)
.gemini/cache/

# OS files
.DS_Store
Thumbs.db
