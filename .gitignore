# Environment files with secrets
# Root: Backend secrets (Alpaca, Supabase service role, JWT)
.env
.qa-identities.env
# Frontend: Next.js frontend secrets
web/.env.local
web/.env.*.local
# Keep example files for reference (no secrets)
!.env.example
!web/.env.local.example

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environments
.venv/
.python-version

# Testing
.pytest_cache/
.coverage
htmlcov/
.benchmarks/
.hypothesis/

# Linting / Type checking
.ruff_cache/
.mypy_cache/

# IDE
.vscode/
.idea/
.cursor/
.claude/

# Logs
*.log
logs/

# Temporary files
# Ignore everything in the temp folder...
temp/*
# ...but don't ignore the .gitkeep file itself
!temp/.gitkeep

# Joblib cache (market data)
.gemini/cache/

# Supabase temp (contains live project ref, org ID, pooler URL — never commit)
supabase/.temp/

# OS files
.DS_Store
Thumbs.db

# Node
node_modules/
.npm/

# Next.js
.next/
tsconfig.tsbuildinfo
web/out/
web/temp-next-build*/

# Playwright / Testing
playwright-report/
test-results/
.playwright-cli/
output/playwright/

# Editor swap files
**/*.swp

# Git worktrees
.worktrees/
