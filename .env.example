# Argus Configuration Example
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED: Alpaca API Credentials (Market Data)
# =============================================================================
# Get your API keys from: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Use paper trading endpoints (set to false for live data)
ALPACA_PAPER_TRADING=true

# =============================================================================
# OPTIONAL: Market Data Caching (Development/Backtesting)
# =============================================================================
# Enable disk caching for market data API calls
# Useful for local development with frequent restarts
# Cache location: .gemini/cache/ (auto-created, gitignored)
# Cache TTL: Expires daily at midnight UTC
ENABLE_MARKET_DATA_CACHE=false

# =============================================================================
# OPTIONAL: Portfolio Configuration
# =============================================================================
# Uncomment and customize to override default symbols
# CRYPTO_SYMBOLS=BTC/USD,ETH/USD,XRP/USD
# EQUITY_SYMBOLS=NVDA,QQQ,GLD

# =============================================================================
# OPTIONAL: Rate Limiting
# =============================================================================
# Delay in seconds between API calls (Alpaca limit: 200 req/min)
RATE_LIMIT_DELAY=0.5

# ==============================================================================
# Supabase Configuration
# ==============================================================================
# Find these in Supabase Dashboard: Project Settings -> API
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL

# Used by the frontend (Next.js) for public interactions
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Used by the backend (FastAPI) to write to the DB securely bypassing RLS
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Used by the backend to verify JWT tokens
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# ==============================================================================
# DEVELOPER UTILITIES
# ==============================================================================
# Bypasses Supabase Auth and hydrates a "Mock Developer" session.
# Required for AI agents working on UI features in remote VMs.
# NEXT_PUBLIC_MOCK_AUTH=true
