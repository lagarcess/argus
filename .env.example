# Argus Configuration Example
# Copy this file to .env and fill in your actual values
#
# TWO MAIN LOCAL SCENARIOS:
#   1. DEV MODE: Fast iteration, no persistence, memory-only, synthetic data
#      - Run: .github/dev.sh
#      - API keys can be dummy values unless you test LLM/provider behavior.
#   2. QA MODE: Production-parity manual browser QA
#      - Run: .github/qa.sh
#      - Requires REAL Supabase, OpenRouter, Alpaca, and Postgres pooler values.
#
# The mode scripts are authoritative for runtime mode flags. Keep this file as a
# secrets/defaults template; do not manually juggle mode combinations for normal
# local work.

# =============================================================================
# REQUIRED: Alpaca API Credentials (Market Data)
# DEV MODE: Dummy values OK (e.g., "dummy_dev_key")
# QA MODE: Real Alpaca keys required for asset resolution
# =============================================================================
# Get your API keys from: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Use paper trading endpoints (set to false for live data)
ALPACA_PAPER_TRADING=true

# ==============================================================================
# MARKET DATA PROVIDER MODE
# ==============================================================================
# Controls how Argus resolves assets and fetches market data.
# ENV VAR: ARGUS_MARKET_DATA_PROVIDER_MODE
#
# live_provider: Real Alpaca/Kraken catalog calls (cached by Argus)
#   Use for: QA Mode and production-parity asset resolution
#
# recorded_provider_fixture: Cached JSON snapshots (repeatable, fast, predictable)
#   Use for: deterministic provider tests/CI only when ARGUS_ASSET_FIXTURE_PATH
#            points at a provider-shaped asset catalog snapshot

# synthetic_unit_fixture: Hardcoded test assets (AAPL, TSLA, BTC, ETH, etc.)
#   Use for: Dev Mode - fast iteration, no API calls, no Alpaca keys needed
#
# Default below is safe for direct local starts. .github/dev.sh and .github/qa.sh
# override it for their respective modes.
ARGUS_MARKET_DATA_PROVIDER_MODE=synthetic_unit_fixture

# Optional, only when ARGUS_MARKET_DATA_PROVIDER_MODE=recorded_provider_fixture.
# Not used by .github/qa.sh unless you intentionally edit that script.
ARGUS_ASSET_FIXTURE_PATH=

# =============================================================================
# OPTIONAL: Portfolio Configuration
# =============================================================================
# Uncomment and customize to override default symbols
# CRYPTO_SYMBOLS=BTC/USD,ETH/USD,XRP/USD
# EQUITY_SYMBOLS=NVDA,QQQ,GLD

# =============================================================================
# OPTIONAL: Rate Limiting
# =============================================================================
# Delay in seconds between API calls (Alpaca limit: 200 req/min)
RATE_LIMIT_DELAY=0.5

# =============================================================================
# REQUIRED: Environment Profile
# =============================================================================
# Single canonical environment selector for backend + frontend parity.
# Allowed values: development | production
APP_ENV=development
NEXT_PUBLIC_APP_ENV=${APP_ENV}

# Render Python services use Render's managed Poetry runtime. Keep this pinned
# instead of installing Poetry inside the build command.
POETRY_VERSION=2.1.3

# Local API URL (Frontend needs this to talk to the FastAPI backend)
# Default: http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_ARGUS_API_URL=http://127.0.0.1:8000/api/v1

# Mail fallback used only if in-app support requests cannot be submitted.
NEXT_PUBLIC_ARGUS_SUPPORT_EMAIL=support@argus.local

# Comma-separated browser origins allowed to call the backend from non-local
# deployments. Localhost dev origins are always included by the API.
# Render private-alpha launch:
# ARGUS_CORS_ALLOW_ORIGINS=https://argus-app-suz5.onrender.com
ARGUS_CORS_ALLOW_ORIGINS=

# ==============================================================================
# Supabase Configuration & Persistence Model
# ==============================================================================
# PERSISTENCE MODE:
#   memory: Ephemeral (good for Dev Mode - no Supabase needed, everything lost on restart)
#   supabase: Durable (required for QA Mode - full message/run/strategy persistence)
# .github/dev.sh and .github/qa.sh override this for normal local use.
ARGUS_PERSISTENCE_MODE=memory

# CHECKPOINT MODE (LangGraph runtime state):
#   memory: No persistence across server restarts (good for Dev Mode)
#   postgres: Persists to Supabase PostgreSQL (required for reload testing in QA Mode)
# If omitted, uses postgres when a script-provided Postgres connection is present;
# otherwise memory.
# .github/dev.sh and .github/qa.sh override this for normal local use.
ARGUS_CHECKPOINTER_MODE=memory

# DEV FALLBACK:
#   true: If Supabase writes fail, silently fall back to memory (tolerant, good for Dev Mode)
#   false: If Supabase writes fail, propagate error (strict, required for QA Mode)
# .github/dev.sh and .github/qa.sh override this for normal local use.
ARGUS_DEV_MEMORY_FALLBACK=false

# ==============================================================================
# PRIVATE-ALPHA FEATURE FLAGS
# ==============================================================================
# Spanish is part of the private-alpha language surface. Feature-development
# gates below remain default-off unless explicitly testing incomplete surfaces.

# Spanish (Latin America) private-alpha language option
# DEV MODE: true
# QA MODE: true
NEXT_PUBLIC_ENABLE_SPANISH=true

# Strategies surface (Saved backtest ideas)
# DEV MODE: false (feature incomplete)
# QA MODE: false (feature incomplete)
ARGUS_STRATEGIES_ENABLED=false
NEXT_PUBLIC_STRATEGIES_ENABLED=false

# Backtest jobs shadow mode (API creates durable queued job rows while keeping
# the current in-process backtest result as the user-facing response)
# DEV MODE: false
# QA MODE: false unless explicitly validating Slice 2
ARGUS_BACKTEST_JOBS_SHADOW_ENABLED=false

# Backtest jobs workflow dispatch (starts a Render Workflow task after creating
# the durable job; still returns the current in-process result).
# Operational modes are synced with .github/render-env-sync.sh:
# - api-safe-off: all API workflow flags false; default for tester sessions.
# - api-proof-shadow-on: proof-only workflow_proof dispatch; infra validation.
# - api-real-workflow-on: real run_backtest_job dispatch; use only after the
#   frontend can render durable async job state.
# DEV MODE: false
# QA MODE: false unless explicitly validating workflow dispatch
ARGUS_BACKTEST_JOBS_DISPATCH_ENABLED=false
ARGUS_BACKTEST_WORKFLOW_TASK=argus-backtests/workflow_proof
ARGUS_BACKTEST_WORKFLOW_EXECUTION_ENABLED=false
ARGUS_BACKTEST_REAL_WORKFLOW_TASK=argus-backtests/run_backtest_job
ARGUS_BACKTEST_JOBS_USER_RUNNING_LIMIT=1
ARGUS_BACKTEST_JOBS_USER_QUEUED_LIMIT=2
ARGUS_BACKTEST_JOBS_GLOBAL_RUNNING_LIMIT=5
ARGUS_BACKTEST_JOBS_GLOBAL_QUEUED_LIMIT=10
RENDER_API_KEY=your_render_api_key_here

# Collections (Organizational grouping for strategies)
# DEV MODE: false (feature deferred)
# QA MODE: false (feature deferred)
NEXT_PUBLIC_COLLECTIONS_ENABLED=false

# OmniSearch (Unified search across conversations, strategies, results)
# DEV MODE: false (feature incomplete)
# QA MODE: false (feature incomplete)
NEXT_PUBLIC_OMNISEARCH_ENABLED=false

# Chat exploratory suggestions (Follow-up prompt chips)
# DEV MODE: false (being hardened; see Private Launch Contract Hardening plan)
# QA MODE: false (being hardened; see Private Launch Contract Hardening plan)
NEXT_PUBLIC_CHAT_EXPLORATORY_SUGGESTIONS_ENABLED=false

# Private alpha onboarding (Multi-step guided intro)
# DEV MODE: false (feature incomplete)
# QA MODE: false (feature incomplete)
NEXT_PUBLIC_PRIVATE_ALPHA_ONBOARDING_ENABLED=false

# Context packets (Market context injected into explanations)
# DEV MODE: false (optional background task)
# QA MODE: true (recommended for full feature testing)
ARGUS_CONTEXT_PACKETS_ENABLED=true
ARGUS_CONTEXT_PACKET_BUDGET_SECONDS=4

# Supabase Credentials (QA Mode only; can be empty for Dev Mode)
# Find in Supabase Dashboard: Project Settings -> API
# Project URL:
SUPABASE_PROJECT_URL=YOUR_SUPABASE_PROJECT_URL
# Anon public key (frontend - used for public interactions):
SUPABASE_ANON_PUBLIC_KEY=YOUR_SUPABASE_ANON_KEY

# Runtime variables (do not edit directly; derived from canonical values above)
# Backend (FastAPI)
SUPABASE_URL=${SUPABASE_PROJECT_URL}
SUPABASE_ANON_KEY=${SUPABASE_ANON_PUBLIC_KEY}

# Supabase Service Keys (QA Mode only - required for persistent writes and recovery):
# - Service Role Key: backend uses this to bypass RLS and write to DB
# - JWT Secret: backend uses this to verify JWT tokens
# Get these from Supabase Dashboard: Settings -> API -> Service Role Key / JWT Secret
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# Supabase Postgres connection strings (QA Mode only; can be empty for Dev Mode)
# Get from Supabase Dashboard: Connect -> Connection string.
# Keep these typed and unambiguous. .github/qa.sh uses the Session Pooler for
# the runtime checkpointer because it is the persistent-backend option that also
# works on IPv4-only networks. Direct is useful for migrations/psql on networks
# with IPv6 or the Supabase IPv4 add-on. Transaction Pooler is for short-lived
# serverless/edge-style clients, not the local QA runtime.
SUPABASE_POSTGRES_DIRECT_URL=YOUR_SUPABASE_POSTGRES_DIRECT_URL
SUPABASE_POSTGRES_SESSION_POOLER_URL=YOUR_SUPABASE_POSTGRES_SESSION_POOLER_URL
SUPABASE_POSTGRES_TRANSACTION_POOLER_URL=YOUR_SUPABASE_POSTGRES_TRANSACTION_POOLER_URL

# Render Workflow proof validation (not used by the normal chat/runtime path).
# DATABASE_URL is intentionally not declared in this file because .github/qa.sh
# derives it from SUPABASE_POSTGRES_SESSION_POOLER_URL for API QA. Render
# Workflow tasks are short-lived compute, so configure ARGUS_WORKFLOW_DATABASE_URL
# as a Render secret using SUPABASE_POSTGRES_TRANSACTION_POOLER_URL for the
# sandbox/project you are validating against.
ARGUS_WORKFLOW_DATABASE_URL=${SUPABASE_POSTGRES_TRANSACTION_POOLER_URL}
ARGUS_RENDER_WORKFLOW_PROOF_TASK=argus-backtests/workflow_proof
ARGUS_WORKFLOW_PROOF_PLAN=starter
ARGUS_BACKTEST_WORKFLOW_TIMEOUT_SECONDS=300

# Read-only stale backtest job scan used by .github/warmup-render.sh when present.
ARGUS_STALE_JOBS_SUPABASE_URL=${SUPABASE_PROJECT_URL}
ARGUS_STALE_JOBS_SUPABASE_SERVICE_ROLE_KEY=${SUPABASE_SERVICE_ROLE_KEY}

# Privacy-safe alpha ops metrics extractor over existing backtest job metadata.
ARGUS_ALPHA_METRICS_SUPABASE_URL=${SUPABASE_PROJECT_URL}
ARGUS_ALPHA_METRICS_SUPABASE_SERVICE_ROLE_KEY=${SUPABASE_SERVICE_ROLE_KEY}

# Frontend (Next.js, browser-exposed names)
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_PROJECT_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_PUBLIC_KEY}

# ==============================================================================
# DEVELOPER UTILITIES
# ==============================================================================
# MOCK AUTH:
#   true: Instantly logs in as "Mock Developer" for fast Dev Mode
#   false: Real Supabase auth, required for production-parity QA Mode
# Recommendation: use true only for local dev; keep false for QA auth validation
NEXT_PUBLIC_MOCK_AUTH=false
ARGUS_MOCK_AUTH=false
# Explicitly expose backend dev endpoints such as /api/v1/dev/reset.
# Keep false outside local/dev-only workflows.
ARGUS_DEV_ENDPOINTS_ENABLED=false
MOCK_USER_EMAIL=mock_user_email
MOCK_USER_PASSWORD=mock_user_password

# ==============================================================================
# CODEX MCP CONFIGURATION (PROJECT-LEVEL)
# ==============================================================================
# Optional fallback for Supabase MCP if OAuth flow does not initialize.
# This is a Supabase Personal Access Token (account-level), not project anon/service keys.
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token_here

# Required for .codex/config.toml -> [mcp_servers.render].
# Reuse the RENDER_API_KEY declared in the backtest workflow dispatch section.

# Supabase MCP uses interactive sign-in (no static token required here).
# Stitch MCP uses local initialization:
#   npx @_davideast/stitch-mcp init

# ==============================================================================
# AI PROVIDER KEYS
# ==============================================================================
# OpenRouter (Required for QA Mode; can be dummy for Dev Mode):
# Primary LLM gateway for chat, artifact planning, and summaries.
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional future provider key if Argus adds direct Groq routing.
# GROQ_API_KEY=your_groq_api_key_here

# Optional contextual intelligence providers. These should enrich explanations,
# not become sources of simulation truth.
TAVILY_API_KEY=your_tavily_api_key_here
FRED_API_KEY=your_fred_api_key_here
# Curated macro context series. CPIAUCSL, CPILFESL, UNRATE, PAYEMS, and INDPRO
# are seasonally adjusted; market-rate and recession indicator series are not
# treated as simulation truth.
ARGUS_FRED_CONTEXT_SERIES=FEDFUNDS,DGS10,DGS2,T10Y2Y,CPIAUCSL,CPILFESL,UNRATE,PAYEMS,INDPRO,USREC
# Best-effort context packet collection for completed runs. Packets are replay
# snapshots for explanations and follow-ups, not simulation truth.
ARGUS_CONTEXT_PACKETS_ENABLED=true
ARGUS_CONTEXT_PACKET_BUDGET_SECONDS=4
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ==============================================================================
# RUNTIME FEATURE FLAGS
# ==============================================================================
# Title Auto-Generation (Both Scenarios):
#   true: AI generates conversation titles after first turn (recommended for QA Mode)
#   false: Manual titles only
ARGUS_TITLE_AUTOGEN_ENABLED=true
ARGUS_TITLE_AUTOGEN_TIMEOUT_MS=250  # ms; fire-and-forget after stream completion
# ==============================================================================
# LLM MODEL ROUTING TIERS
# ==============================================================================
# Format: <provider>/<model_name>
# Keep each fallback in the same capability class as its primary model.

# Tier 0: deterministic runtime, validation, persistence, and simulation truth.
# No model variable belongs to this tier.

# Tier 1: Utility (titles, strategy names, rewrites) - FAST/CHEAP
ARGUS_UTILITY_MODEL=your_utility_model_here
ARGUS_UTILITY_FALLBACK_MODEL=your_utility_fallback_model_here

# Tier 2: Chat (conversation, clarification, education, summaries) - BALANCED
ARGUS_CHAT_MODEL=your_chat_model_here
ARGUS_CHAT_FALLBACK_MODEL=your_chat_fallback_model_here
ARGUS_OPENROUTER_RESULT_SUMMARY_TIMEOUT_SECONDS=30

# Tier 3: Structured (artifact planning, JSON/schema, draft edits) - RELIABLE
ARGUS_STRUCTURED_MODEL=your_structured_model_here
ARGUS_STRUCTURED_FALLBACK_MODEL=your_structured_fallback_model_here

# Tier 4: Context (market context, "why did this happen?") - PREMIUM
ARGUS_CONTEXT_MODEL=your_context_model_here
ARGUS_CONTEXT_FALLBACK_MODEL=your_context_fallback_model_here
